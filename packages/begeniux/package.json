{
  "name": "begeniux",
  "version": "0.2.0",
  "description": "Drop-in adaptive UI engine. Tracks user behavior, asks an agent for a CSS-level adaptation plan, mutates the live DOM in real time.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./copilotkit": {
      "types": "./dist/copilotkit.d.ts",
      "import": "./dist/copilotkit.js",
      "require": "./dist/copilotkit.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@copilotkit/react-core": ">=2.0.0",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "@copilotkit/react-core": { "optional": true },
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@copilotkit/react-core": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "keywords": [
    "react",
    "adaptive-ui",
    "agentic-ui",
    "generative-ui",
    "ag-ui",
    "copilotkit",
    "langgraph",
    "llm",
    "behavioral-ui"
  ],
  "license": "MIT",
  "homepage": "https://github.com/WagnerAgent/BeGeniux#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WagnerAgent/BeGeniux.git"
  },
  "bugs": {
    "url": "https://github.com/WagnerAgent/BeGeniux/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
